# Public HTTPS origin of this service.
BASE_URL=https://miro-mcp.example.com
PORT=3000

# Create an app at https://miro.com/app/settings/user-profile/apps
# Enable expiring access tokens and boards:read, boards:write, identity:read.
MIRO_CLIENT_ID=
MIRO_CLIENT_SECRET=
MIRO_REDIRECT_URI=https://miro-mcp.example.com/oauth/miro/callback

# Development only: bypass the MCP OAuth broker and use one Miro token.
# Never set this in a shared deployment.
# MIRO_ACCESS_TOKEN=
# MIRO_TEAM_ID=

# Reserved for the persistent credential adapter.
TOKEN_ENCRYPTION_KEY=
